{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruslanmv.com/matrix-definitions/schemas/profile.schema.json",
  "title": "Quality Profile",
  "description": "Defines a Matrix Builder quality level and required rule set.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "semver": {
      "type": [
        "string",
        "number"
      ],
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "isoDateTime": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated",
        "placeholder"
      ]
    },
    "qualityLevel": {
      "type": "string",
      "enum": [
        "starter",
        "standard",
        "production",
        "enterprise"
      ]
    },
    "enforcementValue": {
      "type": "string",
      "enum": [
        "off",
        "warn",
        "fail"
      ]
    },
    "ruleId": {
      "type": "string",
      "pattern": "^(RMD|AGENT|ASVS|OWASP|SSDF|SLSA|SUPPLY|GHA|PY|FASTAPI|NEXT|FE|FRONTEND|DOCKER|OBS|MATRIXHUB|DOC|SEC|API)-[0-9]{3,4}$"
    },
    "sourceRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "pathString": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|\\.\\.)"
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "enforcementMatrix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starter": {
          "$ref": "#/$defs/enforcementValue"
        },
        "standard": {
          "$ref": "#/$defs/enforcementValue"
        },
        "production": {
          "$ref": "#/$defs/enforcementValue"
        },
        "enterprise": {
          "$ref": "#/$defs/enforcementValue"
        }
      },
      "minProperties": 1
    }
  },
  "required": [
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schemaVersion"
    },
    "profile": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string"
    },
    "required_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleId"
      },
      "uniqueItems": true
    },
    "default_enforcement": {
      "$ref": "#/$defs/enforcementValue"
    },
    "quality_levels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/qualityLevel"
      },
      "uniqueItems": true
    },
    "default": {
      "$ref": "#/$defs/qualityLevel"
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "extends": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "levels": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
