{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruslanmv.com/matrix-definitions/schemas/rmd-rule.schema.json",
  "title": "Ruslan Magana Definition Rule",
  "description": "Strict schema for RMD rules. RMDs define the control philosophy of Matrix Builder: AI coders are workers, not architects.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "semver": {
      "type": [
        "string",
        "number"
      ],
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "isoDateTime": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated",
        "placeholder"
      ]
    },
    "qualityLevel": {
      "type": "string",
      "enum": [
        "starter",
        "standard",
        "production",
        "enterprise"
      ]
    },
    "enforcementValue": {
      "type": "string",
      "enum": [
        "off",
        "warn",
        "fail"
      ]
    },
    "ruleId": {
      "type": "string",
      "pattern": "^(RMD|AGENT|ASVS|OWASP|SSDF|SLSA|SUPPLY|GHA|PY|FASTAPI|NEXT|FE|FRONTEND|DOCKER|OBS|MATRIXHUB|DOC|SEC|API)-[0-9]{3,4}$"
    },
    "sourceRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "pathString": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|\\.\\.)"
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "enforcementMatrix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starter": {
          "$ref": "#/$defs/enforcementValue"
        },
        "standard": {
          "$ref": "#/$defs/enforcementValue"
        },
        "production": {
          "$ref": "#/$defs/enforcementValue"
        },
        "enterprise": {
          "$ref": "#/$defs/enforcementValue"
        }
      },
      "minProperties": 1
    }
  },
  "required": [
    "schema_version",
    "id",
    "title",
    "domain",
    "severity",
    "status",
    "version",
    "owner",
    "summary",
    "applies_to",
    "generator",
    "validation",
    "agent_generator",
    "rationale"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schemaVersion"
    },
    "id": {
      "$ref": "#/$defs/ruleId"
    },
    "title": {
      "type": "string",
      "minLength": 8,
      "maxLength": 140
    },
    "domain": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "severity": {
      "$ref": "#/$defs/severity"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "owner": {
      "type": "string",
      "minLength": 3
    },
    "created_at": {
      "$ref": "#/$defs/isoDateTime"
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRef"
      },
      "uniqueItems": true
    },
    "applies_to": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_types"
      ],
      "properties": {
        "project_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "template_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 3
        },
        "required_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathString"
          },
          "uniqueItems": true
        },
        "template_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathString"
          },
          "uniqueItems": true
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 3
        },
        "required_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathString"
          },
          "uniqueItems": true
        },
        "required_sections": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "fail_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "allow": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "matrix_builder": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "expose_in_report": {
          "type": "boolean"
        },
        "report_section": {
          "type": "string"
        },
        "failure_message": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "agent_generator": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "enforcement"
      ],
      "properties": {
        "enforcement": {
          "$ref": "#/$defs/enforcementMatrix"
        }
      }
    },
    "exceptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "requires_expiry": {
          "type": "boolean"
        },
        "max_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        }
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 20
    },
    "control": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "immutable_after_generation": {
          "type": "boolean"
        },
        "hash_in_standards_lock": {
          "type": "boolean"
        }
      }
    },
    "matrixhub": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "required_for_publication": {
          "type": "boolean"
        }
      }
    }
  }
}
