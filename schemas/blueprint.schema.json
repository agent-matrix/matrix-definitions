{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruslanmv.com/matrix-definitions/schemas/blueprint.schema.json",
  "title": "Blueprint Spec",
  "description": "High-level blueprint object used before compiling MATRIX_BLUEPRINT.yaml.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "semver": {
      "type": [
        "string",
        "number"
      ],
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "isoDateTime": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated",
        "placeholder"
      ]
    },
    "qualityLevel": {
      "type": "string",
      "enum": [
        "starter",
        "standard",
        "production",
        "enterprise"
      ]
    },
    "enforcementValue": {
      "type": "string",
      "enum": [
        "off",
        "warn",
        "fail"
      ]
    },
    "ruleId": {
      "type": "string",
      "pattern": "^(RMD|AGENT|ASVS|OWASP|SSDF|SLSA|SUPPLY|GHA|PY|FASTAPI|NEXT|FE|FRONTEND|DOCKER|OBS|MATRIXHUB|DOC|SEC|API)-[0-9]{3,4}$"
    },
    "sourceRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "pathString": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|\\.\\.)"
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "enforcementMatrix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starter": {
          "$ref": "#/$defs/enforcementValue"
        },
        "standard": {
          "$ref": "#/$defs/enforcementValue"
        },
        "production": {
          "$ref": "#/$defs/enforcementValue"
        },
        "enterprise": {
          "$ref": "#/$defs/enforcementValue"
        }
      },
      "minProperties": 1
    }
  },
  "required": [
    "schema_version",
    "name",
    "slug",
    "pitch",
    "target_user",
    "goal",
    "stack",
    "quality_level"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schemaVersion"
    },
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "pitch": {
      "type": "string"
    },
    "target_user": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "stack": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "frontend": {
      "type": "object",
      "additionalProperties": true
    },
    "backend": {
      "type": "object",
      "additionalProperties": true
    },
    "database": {
      "type": "object",
      "additionalProperties": true
    },
    "api_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "ai_layer": {
      "type": "object",
      "additionalProperties": true
    },
    "quality_level": {
      "$ref": "#/$defs/qualityLevel"
    },
    "standards_profile": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
