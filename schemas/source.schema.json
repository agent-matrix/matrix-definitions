{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruslanmv.com/matrix-definitions/schemas/source.schema.json",
  "title": "Trusted Source",
  "description": "Trusted source metadata for external standards and official documentation.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "semver": {
      "type": [
        "string",
        "number"
      ],
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "isoDateTime": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated",
        "placeholder"
      ]
    },
    "qualityLevel": {
      "type": "string",
      "enum": [
        "starter",
        "standard",
        "production",
        "enterprise"
      ]
    },
    "enforcementValue": {
      "type": "string",
      "enum": [
        "off",
        "warn",
        "fail"
      ]
    },
    "ruleId": {
      "type": "string",
      "pattern": "^(RMD|AGENT|ASVS|OWASP|SSDF|SLSA|SUPPLY|GHA|PY|FASTAPI|NEXT|FE|FRONTEND|DOCKER|OBS|MATRIXHUB|DOC|SEC|API)-[0-9]{3,4}$"
    },
    "sourceRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "pathString": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|\\.\\.)"
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "enforcementMatrix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starter": {
          "$ref": "#/$defs/enforcementValue"
        },
        "standard": {
          "$ref": "#/$defs/enforcementValue"
        },
        "production": {
          "$ref": "#/$defs/enforcementValue"
        },
        "enterprise": {
          "$ref": "#/$defs/enforcementValue"
        }
      },
      "minProperties": 1
    },
    "sourceObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "authority",
        "tier",
        "type",
        "url",
        "refresh_policy",
        "domains"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/sourceRef"
        },
        "name": {
          "type": "string",
          "minLength": 3
        },
        "authority": {
          "type": "string",
          "minLength": 2
        },
        "tier": {
          "type": [
            "integer",
            "string"
          ],
          "enum": [
            1,
            2,
            3,
            "1",
            "2",
            "3"
          ]
        },
        "type": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "refresh_policy": {
          "type": "string",
          "enum": [
            "daily",
            "weekly",
            "monthly",
            "quarterly",
            "manual"
          ]
        },
        "domains": {
          "$ref": "#/$defs/stringArray"
        }
      }
    }
  },
  "required": [
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schemaVersion"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceObject"
      },
      "uniqueItems": true
    },
    "id": {
      "$ref": "#/$defs/sourceRef"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "authority": {
      "type": "string",
      "minLength": 2
    },
    "tier": {
      "type": [
        "integer",
        "string"
      ],
      "enum": [
        1,
        2,
        3,
        "1",
        "2",
        "3"
      ]
    },
    "type": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "refresh_policy": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "quarterly",
        "manual"
      ]
    },
    "domains": {
      "$ref": "#/$defs/stringArray"
    }
  }
}
